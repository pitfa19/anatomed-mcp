# Copy to .env (gitignored) and fill in.

# Where the widget fetches GLB models from (public Supabase Storage origin).
# After running `npm run upload:assets`, set this to the printed value.
# If unset, the server serves GLBs locally from /assets (dev / tunnel fallback).
ASSET_BASE_URL=https://uafyfwyyqzunabpuftue.supabase.co/storage/v1/object/public/models

# Port the MCP server listens on.
PORT=3000

# --- only needed to (re)upload assets: scripts/upload-assets.ts ---
SUPABASE_URL=https://uafyfwyyqzunabpuftue.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__server_side_only__never_commit__
MODELS_BUCKET=models
